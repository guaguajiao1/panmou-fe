{
	// 组件自动引入规则
	"easycom": {
		// 是否开启自动扫描
		"autoscan": true,
		// 以正则方式自定义组件匹配规则
		"custom": {
			// uni-ui 规则如下配置
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			// 以 Xtx 开头的组件，在 components 文件夹中查找引入（需要重启服务器）
			"^Xtx(.*)": "@/components/Xtx$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/shop/shop",
			"style": {
				"navigationBarTitleText": "shop"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "uni-app"
			}
		},
		{
			"path": "pages/product/product",
			"style": {
				"navigationBarTitleText": "product"
			}
		},
		{
			"path": "pages/cart/cart",
			"style": {
				"navigationBarTitleText": "cart"
			}
		},
		{
			"path": "pages/chewy_cart/chewy_cart",
			"style": {
				"navigationBarTitleText": "chewy_cart"
			}
		},
		{
			"path": "pages/place_order/place_order",
			"style": {
				"navigationBarTitleText": "place_order"
			}
		},
		{
			"path": "pages/account/address_list/address_list",
			"style": {
				"navigationBarTitleText": "address_list"
			}
		},
		{
			"path": "pages/account/address_edit/address_edit",
			"style": {
				"navigationBarTitleText": "address"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "panmou",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#FFFFFF"
	},
	"uniIdRouter": {
		"loginPage": "pages/login/login",
		"needLogin": []
	}
}
