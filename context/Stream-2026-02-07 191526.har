            "text" : "{\"success\":true,\"code\":200,\"message\":\"请求成功\",\"datetime\":\"2026-02-07 19:13:43\",\"traceId\":\"47503bb6cd394c54ad612e6f319f3e76\",\"data\":{\"product\":{\"code\":\"521384\",\"type\":1,\"name\":\"金拱豪门菠萝安格斯厚牛堡\",\"image\":\"https:\/\/menu-img.mcd.cn\/pcm\/prod\/menu\/ProductPool\/product\/MS_521384_600.png\",\"price\":3450,\"priceText\":\"34.5\",\"customizationMode\":1,\"customization\":{\"options\":[{\"code\":\"120512\",\"name\":\"切块生菜\",\"mode\":1,\"displayMode\":2,\"image\":\"https:\/\/menu-img.mcd.cn\/pcm\/prod\/menu\/ProductPool\/grill\/MS_120512_500.png\",\"quantity\":1,\"realQuantity\":1,\"soldOut\":false,\"checked\":1,\"price\":0},{\"code\":\"102215\",\"name\":\"高达干酪片\",\"mode\":1,\"displayMode\":2,\"image\":\"https:\/\/menu-img.mcd.cn\/pcm\/prod\/menu\/ProductPool\/grill\/MS_102215_500.jpg\",\"quantity\":1,\"realQuantity\":1,\"soldOut\":false,\"checked\":1,\"price\":0},{\"code\":\"120534\",\"name\":\"蜜糖芥末沙拉酱\",\"mode\":1,\"displayMode\":2,\"image\":\"https:\/\/menu-img.mcd.cn\/pcm\/prod\/menu\/ProductPool\/grill\/MS_120534_500.png\",\"quantity\":1,\"realQuantity\":1,\"soldOut\":false,\"checked\":1,\"price\":0}],\"items\":[]},\"tags\":[],\"desc\":\"选用100％安格斯牛肉饼，3:7的黄金肥瘦比，搭配酸甜多汁的厚切菠萝片，佐以蜂蜜芥末酱，一口下去，汁水迸发，菠萝的果香和牛肉的脂香在嘴里萦绕，口感厚实层次丰富，口口吃得到的大满足。\\n主要原料：面包、牛肉、芝士、菠萝、生菜、风味酱\\n*“3:7肥瘦比”是指生牛肉饼中的肥肉与瘦肉的近似比例约为3:7，个体可能略有差异。\\n**100%安格斯是指金拱豪门菠萝安格斯厚牛堡中的牛肉饼为纯安格斯牛肉。\",\"bu\":1,\"links\":[],\"priceFormula\":true,\"limitedQuantity\":0},\"maxPurchaseQuantity\":99,\"calcPrice\":true,\"biasGrillsFlag\":true}}",
